rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net Rule - Default Deny other collections
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Real Estate Application Collections ---

    // 1. Properties Collection
    match /properties/{propertyId} {
      allow read, write: if true;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 3. Inquiries Collection
    match /inquiries/{inquiryId} {
      allow read, write: if true;
    }

    // 4. Notifications Collection
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // 5. Testimonials Collection
    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }

    // 6. Agencies Collection
    match /agencies/{agencyId} {
      allow read, write: if true;
    }

    // 7. Favorites Collection
    match /favorites/{favoriteId} {
      allow read, write: if true;
    }

    // 8. Agency Logs Collection
    match /agency_logs/{logId} {
      allow read, write: if true;
    }
  }
}
